@app.callback(
    Output("chat-img-store",   "data"),
    Output("chat-img-preview", "children"),
    Input("chat-upload", "contents"),
    prevent_initial_call=True,
)
def store_uploaded_image(contents):
    if not contents:
        return None, ""
    preview = html.Img(src=contents, style={
        "maxHeight": "80px",
        "borderRadius": "8px",
        "marginBottom": "4px",
        "border": "1px solid rgba(0,212,170,0.3)",
    })
    return contents, preview


@app.callback(
    Output("chat-messages",    "children"),
    Output("chat-history",     "data"),
    Output("chat-input",       "value"),
    Output("chat-img-store",   "data",     allow_duplicate=True),
    Output("chat-img-preview", "children", allow_duplicate=True),
    Input("chat-send-btn", "n_clicks"),
    Input("chat-input",    "n_submit"),
    State("chat-input",    "value"),
    State("chat-history",  "data"),
    State("chat-messages", "children"),
    State("chat-img-store","data"),
    prevent_initial_call=True,
)
def send_chat_message(n_clicks, n_submit, user_text, history, current_msgs, img_data):
    if not user_text and not img_data:
        raise dash.exceptions.PreventUpdate

    # ── Build user bubble ──
    bubble_children = []
    if img_data:
        bubble_children.append(html.Img(src=img_data, style={
            "maxWidth": "100%", "borderRadius": "6px",
            "marginBottom": "4px", "display": "block",
        }))
    if user_text:
        bubble_children.append(html.Span(user_text))

    user_bubble = html.Div(
        bubble_children,
        className="msg-bubble msg-user",
    )

    # ── Build API payload ──
    content = []
    if user_text:
        content.append({"type": "text", "text": user_text})
    if img_data:
        content.append({"type": "image_url", "image_url": {"url": img_data}})

    history = list(history)
    history.append({"role": "user", "content": content})

    try:
        response = requests.post(
            "https://api.openai.com/v1/chat/completions",
            headers={
                "Authorization": f"Bearer {OPENAI_API_KEY}",
                "Content-Type": "application/json",
            },
            json={
                "model": "gpt-4o",
                "messages": [
                    {
                        "role": "system",
                        "content": (
                            "You are an expert energy data analyst assistant embedded in a "
                            "Global Energy Dashboard. Answer questions about energy production, "
                            "consumption, renewables, fossil fuels, carbon intensity, and related "
                            "topics with precise, insightful analysis. If an image is provided, "
                            "analyse it in detail. Reply in the same language the user uses."
                        ),
                    },
                    *history,
                ],
                "max_tokens": 600,
            },
            timeout=30,
        )
        reply = response.json()["choices"][0]["message"]["content"]
    except requests.exceptions.Timeout:
        reply = "⏱️ الطلب أخد وقت طويل، حاول تاني."
    except Exception as e:
        reply = f"❌ حصل خطأ: {str(e)}"

    history.append({"role": "assistant", "content": reply})

    # ── Build assistant bubble ──
    assistant_bubble = html.Div(
        [html.Span("⚡ ", style={"opacity": "0.7"}), reply],
        className="msg-bubble msg-assistant",
        style={"whiteSpace": "pre-wrap"},
    )

    new_msgs = list(current_msgs) + [user_bubble, assistant_bubble]
    return new_msgs, history, "", None, ""


